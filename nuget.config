<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<packageSources>
		<add key="auth-service" value="https://pkgs.dev.azure.com/snapdetective/snapdetective/_packaging/auth-service/nuget/v3/index.json" />
		<add key="github" value="https://nuget.pkg.github.com/NoahtlHoff/index.json" />
	</packageSources>
	<packageSourceCredentials>
		<auth-service>
			<add key="Username" value="NoahtlHoff" />
			<add key="ClearTextPassword" value="%AZURE_ARTIFACTS_PAT%" />
		</auth-service>
		<github>
			<add key="Username" value="NoahtlHoff" />
			<add key="ClearTextPassword" value="%GITHUB_TOKEN%" />
		</github>
	</packageSourceCredentials>
</configuration>